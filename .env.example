# Root environment variables configuration for Docker Compose & Local Development

# Google AI Studio Gemini API Settings
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash

# Web Frontend Settings
API_URL=http://api:8000
NEXT_PUBLIC_APP_NAME=Nutrition Scanner

# API Gateway & Backend Settings
DATABASE_URL=sqlite+aiosqlite:///./nutrition_scanner.db
INFERENCE_SERVICE_URL=http://inference:8001
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads
LOG_LEVEL=INFO
ENV=development
MAX_IMAGE_SIZE_MB=5

# Optional External Cloud Storage (Supabase)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=nutrition-images
