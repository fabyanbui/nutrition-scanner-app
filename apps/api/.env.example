# FastAPI Backend Environment Variables
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
DATABASE_URL=sqlite+aiosqlite:///./nutrition_scanner.db
INFERENCE_SERVICE_URL=http://127.0.0.1:8001
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads
LOG_LEVEL=INFO
ENV=development
MAX_IMAGE_SIZE_MB=5

# Optional Supabase Cloud Storage Configuration
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=nutrition-images
